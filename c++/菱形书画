#include <stdio.h>

int main()
{
    int line = 0;
    // 循环读取输入，直到EOF
    while (scanf("%d", &line) != EOF)
    {
        // 上半部分：正三角形（line+1行）
        for (int i = 0; i < line + 1; i++)
        {
            // 打印左侧空格
            for (int j = 0; j < line - i; j++)
            {
                printf(" ");
            }
            // 打印*
            for (int j = 0; j < i + 1; j++)
            {
                printf("* ");
            }
            printf("\n");
        }

        // 下半部分：倒三角形（line行）
        for (int i = 0; i < line; i++)
        {
            // 打印左侧空格
            for (int j = 0; j < i + 1; j++)
            {
                printf(" ");
            }
            // 打印*
            for (int j = 0; j < line - i; j++)
            {
                printf("* ");
            }
            printf("\n");
        }
        // 多个输入时，分隔不同菱形
        printf("------------------------\n");
    }
    return 0;
}
